generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DIRECTOR
  EMPLOYEE
  PATIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  BLOCKED
}

enum EmployeeFunction {
  DOCTOR
  NURSE
  PARAMEDIC
  RECEPTIONIST
  SECURITY
  IT_ADMIN
}

enum BedStatus {
  FREE
  OCCUPIED
  BLOCKED
  CLEANING
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lastLoginAt  DateTime?  @map("last_login_at")

  patient  Patient?
  employee Employee?

  @@map("users")
}

model Patient {
  id                 Int      @id @default(autoincrement())
  userId             String?  @unique @map("user_id")
  firstName          String   @map("first_name")
  lastName           String   @map("last_name")
  pesel              String   @unique
  email              String   @unique
  isAuthorized       Boolean  @default(false) @map("is_authorized")
  assignedDoctorName String?  @map("assigned_doctor_name")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("patients")
}

model Employee {
  id               Int              @id @default(autoincrement())
  userId           String?          @unique @map("user_id")
  firstName        String           @map("first_name")
  lastName         String           @map("last_name")
  email            String           @unique
  phoneNumber      String           @map("phone_number")
  employeeFunction EmployeeFunction @map("employee_function")
  departmentName   String?          @map("department_name")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("employees")
}

model HospitalDepartment {
  id             Int      @id @default(autoincrement())
  name           String
  code           String   @unique
  floor          Int
  headDoctorName String   @map("head_doctor_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  rooms HospitalRoom[]

  @@map("hospital_departments")
}

model HospitalRoom {
  id           Int      @id @default(autoincrement())
  departmentId Int      @map("department_id")
  number       String
  type         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department HospitalDepartment @relation(fields: [departmentId], references: [id])
  beds       HospitalBed[]

  @@unique([departmentId, number])
  @@map("hospital_rooms")
}

model HospitalBed {
  id          Int       @id @default(autoincrement())
  roomId      Int       @map("room_id")
  number      String
  status      BedStatus @default(FREE)
  patientName String?   @map("patient_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  room HospitalRoom @relation(fields: [roomId], references: [id])

  @@unique([roomId, number])
  @@map("hospital_beds")
}