generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DIRECTOR
  EMPLOYEE
  PATIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  BLOCKED
}

enum EmployeeFunction {
  DOCTOR
  NURSE
  PARAMEDIC
  RECEPTIONIST
  SECURITY
  IT_ADMIN
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lastLoginAt  DateTime?  @map("last_login_at")

  patient  Patient?
  employee Employee?

  @@map("users")
}

model Patient {
  id                 Int      @id @default(autoincrement())
  userId             String?  @unique @map("user_id")
  firstName          String   @map("first_name")
  lastName           String   @map("last_name")
  pesel              String   @unique
  email              String   @unique
  isAuthorized       Boolean  @default(false) @map("is_authorized")
  assignedDoctorName String?  @map("assigned_doctor_name")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("patients")
}

model Employee {
  id               Int              @id @default(autoincrement())
  userId           String?          @unique @map("user_id")
  firstName        String           @map("first_name")
  lastName         String           @map("last_name")
  email            String           @unique
  phoneNumber      String           @map("phone_number")
  employeeFunction EmployeeFunction @map("employee_function")
  departmentName   String?          @map("department_name")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("employees")
}