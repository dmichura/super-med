generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DIRECTOR
  EMPLOYEE
  PATIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  BLOCKED
}

enum EmployeeFunction {
  DOCTOR
  NURSE
  PARAMEDIC
  RECEPTIONIST
  SECURITY
  IT_ADMIN
}

enum BedStatus {
  FREE
  OCCUPIED
  BLOCKED
  CLEANING
}

enum MedicalRecordType {
  VISIT
  DIAGNOSIS
  PRESCRIPTION
  LAB_RESULT
  DISCHARGE_SUMMARY
}

enum MedicalRecordStatus {
  DRAFT
  FINAL
  ARCHIVED
}

enum MedicalRecordAuditAction {
  VIEW
  CREATE
  UPDATE
  EXPORT
}

enum DocumentType {
  MEDICAL_SCAN
  LAB_ATTACHMENT
  CONSENT
  ADMINISTRATIVE
  DISCHARGE_FILE
}

enum DocumentStatus {
  UPLOADED
  VERIFIED
  REJECTED
  ARCHIVED
}

enum AuditAction {
  LOGIN
  LOGOUT
  VIEW
  CREATE
  UPDATE
  DELETE
  EXPORT
  AUTHORIZE
}

enum AuditResourceType {
  AUTH
  PATIENT
  EMPLOYEE
  MEDICAL_RECORD
  HOSPITAL_STRUCTURE
  REPORT
}

enum AuditResult {
  SUCCESS
  DENIED
  ERROR
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lastLoginAt  DateTime?  @map("last_login_at")

  patient  Patient?
  employee Employee?

  @@map("users")
}

model Patient {
  id                 Int      @id @default(autoincrement())
  userId             String?  @unique @map("user_id")
  firstName          String   @map("first_name")
  lastName           String   @map("last_name")
  pesel              String   @unique
  email              String   @unique
  isAuthorized       Boolean  @default(false) @map("is_authorized")
  assignedDoctorName String?  @map("assigned_doctor_name")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  medicalRecords MedicalRecord[]
  documents PatientDocument[]

  @@map("patients")
}

model Employee {
  id               Int              @id @default(autoincrement())
  userId           String?          @unique @map("user_id")
  firstName        String           @map("first_name")
  lastName         String           @map("last_name")
  email            String           @unique
  phoneNumber      String           @map("phone_number")
  employeeFunction EmployeeFunction @map("employee_function")
  departmentName   String?          @map("department_name")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("employees")
}

model HospitalDepartment {
  id             Int      @id @default(autoincrement())
  name           String
  code           String   @unique
  floor          Int
  headDoctorName String   @map("head_doctor_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  rooms HospitalRoom[]

  @@map("hospital_departments")
}

model HospitalRoom {
  id           Int      @id @default(autoincrement())
  departmentId Int      @map("department_id")
  number       String
  type         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department HospitalDepartment @relation(fields: [departmentId], references: [id])
  beds       HospitalBed[]

  @@unique([departmentId, number])
  @@map("hospital_rooms")
}

model HospitalBed {
  id          Int       @id @default(autoincrement())
  roomId      Int       @map("room_id")
  number      String
  status      BedStatus @default(FREE)
  patientName String?   @map("patient_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  room HospitalRoom @relation(fields: [roomId], references: [id])

  @@unique([roomId, number])
  @@map("hospital_beds")
}

model MedicalRecord {
  id             Int                 @id @default(autoincrement())
  code           String              @unique
  patientId      Int                 @map("patient_id")
  doctorName     String              @map("doctor_name")
  departmentName String              @map("department_name")
  type           MedicalRecordType
  title          String
  createdAt      DateTime            @map("created_at")
  status         MedicalRecordStatus
  isSensitive    Boolean             @default(true) @map("is_sensitive")
  description    String
  updatedAt      DateTime            @updatedAt @map("updated_at")

  patient    Patient                   @relation(fields: [patientId], references: [id])
  auditTrail MedicalRecordAuditEntry[]

  @@map("medical_records")
}

model MedicalRecordAuditEntry {
  id              Int                      @id @default(autoincrement())
  medicalRecordId Int                      @map("medical_record_id")
  actorName       String                   @map("actor_name")
  action          MedicalRecordAuditAction
  accessedAt      DateTime                 @map("accessed_at")
  reason          String
  createdAt       DateTime                 @default(now()) @map("created_at")

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@map("medical_record_audit_entries")
}

model PatientDocument {
  id          Int            @id @default(autoincrement())
  code        String         @unique
  patientId   Int            @map("patient_id")
  type        DocumentType
  fileName    String         @map("file_name")
  status      DocumentStatus
  uploadedBy  String         @map("uploaded_by")
  uploadedAt  DateTime       @map("uploaded_at")
  isSensitive Boolean        @default(true) @map("is_sensitive")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("patient_documents")
}

model AuditEvent {
  id           Int               @id @default(autoincrement())
  code         String            @unique
  actorName    String            @map("actor_name")
  actorRole    String            @map("actor_role")
  action       AuditAction
  resourceType AuditResourceType @map("resource_type")
  resourceName String            @map("resource_name")
  occurredAt   DateTime          @map("occurred_at")
  ipAddress    String            @map("ip_address")
  result       AuditResult
  reason       String
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@map("audit_events")
}